generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "mongodb"
  url  	    = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
  SELLER
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  VACATION
}

enum ProductStatus {
  ACTIVE
  DISABLED
  HIDDEN
}

enum SellerApplicationStatus {
  NOT_STARTED
  PENDING
  ACCEPTED
  REJECTED
}

enum OrderStatus {
  PROCESSING
  COMPLETED
  PENDING_TRANSFER
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PAID
  PENDING
  FAILED
  REFUNDED
}

model Account {
  id                 String  @id @default(auto()) @map("_id") @db.ObjectId
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  email String
  token String @unique
  expires DateTime

  @@unique([email, token])
}

model PasswordResetToken {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  email String
  token String @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorToken {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  email String
  token String @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorConfirmation {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
}

model User {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  username              String?   @unique
  email                 String?   @unique
  password              String?
  emailVerified         DateTime?
  passwordHash          String?
  image                 String?
  accounts              Account[]
  member                Member?
  seller                Seller?
  orders                Order[]
  status                AccountStatus?  @default(ACTIVE)
  sellerApplication     SellerApplication?
  suggestion            Suggestion[]
  isTwoFactorEnabled    Boolean @default(false)
  twoFactorConfirmation TwoFactorConfirmation?
  role                  UserRole  @default(MEMBER)
  reviewsGiven          Review[] @relation("Reviewer")
  reviewsReceived       Review[] @relation("Reviewed")
  sessions              Session[]
  conversations         UserConversation[]
  sentMessages          Message[] @relation("MessageSender")

  createdAt	        DateTime @default(now())
  updatedAt	        DateTime @updatedAt
}

model Member {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  userId            String    @unique
  firstName         String
  lastName          String
  userBio           String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt	        DateTime @default(now())
  updatedAt	        DateTime @updatedAt
}

model Address {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  streetAddress String
  streetAddress2 String?  // For apartment numbers, suite numbers, etc.
  city          String
  state         String?   // Optional for countries without states
  province      String?   // Alternative to state for some countries
  postalCode    String    // Can handle various formats (ZIP, PIN, etc.)
  country       String
  isDefault     Boolean  @default(true)
  sellerId      String
  seller        Seller   @relation(fields: [sellerId], references: [userId])
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([sellerId])
}

model Seller {
  id		                    String    @id @default(auto()) @map("_id") @db.ObjectId
  userId	                  String    @unique
  shopName	                String    @unique
  shopNameSlug              String    @unique // URL-friendly shop name
  shopTagLine               String?
  shopDescription           String?
  applicationAccepted       Boolean   @default(false)
  stripeConnected	          Boolean		@default(false)
  connectedAccountId        String?   @unique // Optional, but required for selling
  totalSales	              Int       @default(0)
  totalProducts	            Int       @default(0)
  acceptsCustom             Boolean   @default(false)
  isWomanOwned             Boolean   @default(false)
  isMinorityOwned          Boolean   @default(false)
  isLGBTQOwned             Boolean   @default(false)
  isVeteranOwned           Boolean   @default(false)
  isSustainable            Boolean   @default(false)
  isCharitable             Boolean   @default(false)
  valuesPreferNotToSay     Boolean   @default(false)
  products	                Product[]
  order                     Order[]
  addresses                 Address[]
  user		                  User		@relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt	      DateTime @default(now())
  updatedAt	      DateTime @updatedAt
}

model SellerApplication {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  userId              String    @unique
  craftingProcess     String
  portfolio           String
  interestInJoining   String
  applicationApproved Boolean @default(false)
  user		            User		@relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt	      DateTime @default(now())
}

model Product {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  userId                String
  name                  String
  description           Json
  price                 Float
  status                String   @default("HIDDEN")
  shippingCost          Float?   // Only required if product is physical
  handlingFee           Float?
  itemWeight            Int?
  itemLength            Int?
  itemWidth             Int?
  itemHeight            Int?
  shippingNotes         String?
  freeShipping          Boolean  @default(false)
  isDigital             Boolean
  stock                 Int      @default(1)
  images                String[] // Array of image URLs
  productFile           String?  // Only required if product is digital
  numberSold            Int      @default(0)
  onSale                Boolean  @default(false)
  discount              Int?     // Only if the product is on sale
  primaryCategory       String
  secondaryCategory     String
  tags                  String[]
  materialTags          String[]
  options               Json?
  inStockProcessingTime Int?
  outStockLeadTime      Int?
  howItsMade            String?
  productDrop           Boolean  @default(false)
  NSFW                  Boolean		@default(false)
  order                 Order[]
  dropDate              DateTime?
  discountEndDate       DateTime?
  reviews               Review[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  seller          Seller?    @relation(fields: [userId], references: [userId])
}

model Suggestion {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String
  title             String
  description       String
  type              String   // e.g., "Feature", "Change", "Addition"
  role              String   // "Seller" or "Member"
  
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

model ContactUs {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  email             String
  reason            String
  helpDescription   String

  createdAt         DateTime @default(now())
}

model Order {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  userId            String
  buyerEmail       String
  buyerName         String
  sellerId          String
  shopName          String
  productId         String
  productName       String
  quantity          Int
  totalAmount       Float
  productPrice      Float
  shippingCost      Float
  stripeFee         Float     @default(0)
  isDigital         Boolean   @default(false)
  status            OrderStatus
  paymentStatus     PaymentStatus
  stripeSessionId   String
  stripeTransferId  String?
  shippingAddress   Json?
  discount          Json?
  reviews           Review[]
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id])
  seller            Seller    @relation(fields: [sellerId], references: [userId])
  product           Product   @relation(fields: [productId], references: [id])
}

model HandmadeGuidelines {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   Json
  updatedAt DateTime @updatedAt
}

model PrivacyPolicy {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   Json
  updatedAt DateTime @updatedAt
}

model TemporaryUpload {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  fileKey   String   @unique
  fileUrl   String
  userId    String
  createdAt DateTime @default(now())
  productId String?  // Optional, will be set when the file is associated with a product

  @@index([createdAt]) // Add index for better query performance
  @@index([userId])    // Add index for user queries
}

model Review {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId           String   
  reviewerId        String   
  reviewedId        String   
  productId         String?  
  rating            Int      // 1-5 stars
  comment           String?
  type              String   // "PRODUCT", "SELLER", "BUYER"
  status            String   @default("PENDING") // "PENDING", "PUBLISHED", "EXPIRED"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  expiresAt         DateTime // 2 weeks from order completion
  order             Order    @relation(fields: [orderId], references: [id])
  reviewer          User     @relation("Reviewer", fields: [reviewerId], references: [id])
  reviewed          User     @relation("Reviewed", fields: [reviewedId], references: [id])
  product           Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([reviewerId])
  @@index([reviewedId])
  @@index([productId])
}

model Message {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  content        String
  senderId       String       
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
  conversationId String       
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  users     UserConversation[]
  messages  Message[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model UserConversation {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  userId         String       
  user           User         @relation(fields: [userId], references: [id])
  conversationId String       
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, conversationId])
}
