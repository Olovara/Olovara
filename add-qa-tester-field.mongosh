// MongoDB shell script to add qaTester field to all users
// Run this in mongosh: mongosh <connection-string> < add-qa-tester-field.mongosh
// Or paste directly into mongosh

// Add qaTester field to all users, defaulting to false
db.User.updateMany(
  {},
  {
    $set: {
      qaTester: false
    }
  }
);

// Verify the update
db.User.countDocuments({ qaTester: { $exists: true } });
