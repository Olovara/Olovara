generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "mongodb"
  url  	    = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
  SELLER
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  VACATION
}

enum ProductStatus {
  ACTIVE
  DISABLED
  HIDDEN
}

enum SellerApplicationStatus {
  NOT_STARTED
  PENDING
  ACCEPTED
  REJECTED
}

enum PrimaryCategoryTags {
  ACCESORIES
  TOYS
  CLOTHING
  CRAFT_SUPPLIES
  PATTERNS
}

enum SecondaryCategoryTags {
  AMIGURUMI
  CROCHET
  KINTTING
  TUNISIAN
  SEWING
}

model Account {
  id                 String  @id @default(auto()) @map("_id") @db.ObjectId
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  email String
  token String @unique
  expires DateTime

  @@unique([email, token])
}

model PasswordResetToken {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  email String
  token String @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorToken {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  email String
  token String @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorConfirmation {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
}

model User {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  username              String?   @unique
  email                 String?   @unique
  password              String?
  emailVerified         DateTime?
  passwordHash          String?
  image                 String?
  accounts              Account[]
  member                Member?
  seller                Seller?
  orders                Order[]
  status                AccountStatus?  @default(ACTIVE)
  sellerApplication     SellerApplication?
  suggestion            Suggestion[]
  isTwoFactorEnabled    Boolean @default(false)
  twoFactorConfirmation TwoFactorConfirmation?
  role                  UserRole  @default(MEMBER)

  createdAt	        DateTime @default(now())
  updatedAt	        DateTime @updatedAt
}

model Member {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  userId            String    @unique
  firstName         String
  lastName          String
  userBio           String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt	        DateTime @default(now())
  updatedAt	        DateTime @updatedAt
}

model Seller {
  id		                    String    @id @default(auto()) @map("_id") @db.ObjectId
  userId	                  String    @unique
  shopName	                String    @unique
  shopNameSlug              String    @unique // URL-friendly shop name
  shopTagLine               String?
  shopDescription           String?
  stripeConnected	          Boolean		@default(false)
  connectedAccountId        String?   @unique // Optional, but required for selling
  totalSales	              Int       @default(0)
  totalProducts	            Int       @default(0)
  acceptsCustom             Boolean   @default(false)
  products	                Product[]
  order                     Order[]
  user		                  User		@relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt	      DateTime @default(now())
  updatedAt	      DateTime @updatedAt
}

model SellerApplication {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  userId              String    @unique
  craftingProcess     String
  portfolio           String
  interestInJoining   String
  applicationApproved Boolean @default(false)
  user		            User		@relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt	      DateTime @default(now())
}

model Product {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  userId                String
  name                  String
  description           Json
  price                 Float
  status                String   @default("HIDDEN")
  shippingCost          Float?   // Only required if product is physical
  handlingFee           Float?
  itemWeight            Int?
  itemLength            Int?
  itemWidth             Int?
  itemHeight            Int?
  shippingNotes         String?
  freeShipping          Boolean  @default(false)
  isDigital             Boolean
  stock                 Int      @default(1)
  images                String[] // Array of image URLs
  productFile           String?  // Only required if product is digital
  numberSold            Int      @default(0)
  onSale                Boolean  @default(false)
  discount              Int?     // Only if the product is on sale
  primaryCategory       String
  secondaryCategory     String
  tags                  String[]
  materialTags          String[]
  options               Json?
  inStockProcessingTime Int?
  outStockLeadTime      Int?
  howItsMade            String?
  productDrop           Boolean  @default(false)
  NSFW                  Boolean		@default(false)
  order                 Order[]
  dropDate              DateTime?
  discountEndDate       DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  seller          Seller?    @relation(fields: [userId], references: [userId])
}

model Suggestion {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String
  title             String
  description       String
  type              String   // e.g., "Feature", "Change", "Addition"
  role              String   // "Seller" or "Member"
  
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

model ContactUs {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  email             String
  reason            String
  helpDescription   String

  createdAt         DateTime @default(now())
}

model Order {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String?   // Buyer ID
  buyerEmail     String
  buyerName      String?
  sellerId       String   // Seller ID
  productId      String   // Product being ordered
  productName    String
  quantity       Int      // How many were ordered
  totalAmount    Float    // Final price including shipping and discounts
  shippingCost   Float?   // Only if physical
  discount       Int?     // Applied discount
  isDigital      Boolean  // True if digital product
  status         String   @default("PENDING") // Order status
  paymentStatus  String   @default("UNPAID")  // Payment status
  shippingAddress Json?   // Only required for physical products
  stripeSessionId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User?     @relation(fields: [userId], references: [id])
  seller         Seller   @relation(fields: [sellerId], references: [userId])
  product        Product  @relation(fields: [productId], references: [id])
}

model HandmadeGuidelines {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   Json
  updatedAt DateTime @updatedAt
}

model TemporaryUpload {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  fileKey   String
  fileUrl   String
  userId    String
  createdAt DateTime @default(now())
  productId String?  // Optional, will be set when the file is associated with a product

  @@index([createdAt]) // Add index for better query performance
  @@index([userId])    // Add index for user queries
}