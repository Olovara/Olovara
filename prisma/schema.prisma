generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  VACATION
}

enum ProductStatus {
  DRAFT
  ACTIVE
  DISABLED
  HIDDEN
}

enum SellerApplicationStatus {
  NOT_STARTED
  PENDING
  ACCEPTED
  REJECTED
}

enum OrderStatus {
  PROCESSING
  COMPLETED
  PENDING_TRANSFER
  PENDING
  HELD
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PAID
  PENDING
  FAILED
  REFUNDED
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  id      String   @id @default(auto()) @map("_id") @db.ObjectId
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model PasswordResetToken {
  id      String   @id @default(auto()) @map("_id") @db.ObjectId
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorToken {
  id      String   @id @default(auto()) @map("_id") @db.ObjectId
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorConfirmation {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
}

model User {
  id                    String                 @id @default(auto()) @map("_id") @db.ObjectId
  username              String?                @unique
  email                 String?                @unique
  password              String?
  emailVerified         DateTime?
  passwordHash          String?
  image                 String?
  preferredCurrency     String                 @default("USD") // Store user's preferred currency
  referralCode          String?                @unique // Unique referral code in format YARNNU-XXXX-XXXX
  referredBy            String?                // referralCode of referrer
  referralCount         Int                    @default(0) // how many people they've referred
  
  // Profile fields
  encryptedFirstName    String? // Encrypted first name
  firstNameIV           String? // IV for first name encryption
  firstNameSalt         String? // Salt for first name encryption (GCM)
  encryptedLastName     String?
  lastNameIV            String?  // Initialization vector for last name
  lastNameSalt          String? // Salt for last name encryption (GCM)
  userBio               String? // User bio/description
  
  accounts              Account[]
  member                Member?
  seller                Seller?
  admin                 Admin?
  orders                Order[]
  status                AccountStatus?         @default(ACTIVE)
  sellerApplication     SellerApplication?
  onboardingSurvey      OnboardingSurvey?
  suggestion            Suggestion[]
  upvotes               Upvote[]
  isTwoFactorEnabled    Boolean                @default(false)
  twoFactorConfirmation TwoFactorConfirmation?
  role                  String                 @default("MEMBER")
  permissions           Json[]                 @default([]) // Array of permission objects with expiration
  reviewsGiven          Review[]               @relation("Reviewer")
  reviewsReceived       Review[]               @relation("Reviewed")
  sessions              Session[]
  conversations         UserConversation[]
  sentMessages          Message[]              @relation("MessageSender")
  blogPosts             BlogPost[]
  blogComments          BlogComment[]
  helpArticles          HelpArticle[]
  customOrderSubmissions CustomOrderSubmission[]
  abandonedCarts        AbandonedCart[]
  fraudDetectionEvents  FraudDetectionEvent[]
  userBehaviorEvents    UserBehaviorEvent[]
  searchAnalytics       SearchAnalytics[]
  productInteractions   ProductInteraction[]
  userSessions          UserSession[]
  reportsSubmitted      Report[]        @relation("ReportReporter")
  followers             Follow[]        @relation("UserFollowers") // Sellers this user is following
  wishlists             Wishlist[]
  wishlistItems         WishlistItem[] @relation("UserWishlistItems")
  purchasedItems        WishlistItem[] @relation("WishlistPurchaser")

  //Tracability and fraud detection
  signupIP          String? // IP at signup
  signupLocation    Json? // { country, region, city }
  lastLoginIP       String?
  lastLoginAt       DateTime?
  isProxy           Boolean?  @default(false) // Was signup IP a VPN/proxy?
  fraudScore        Float? // 0.0–1.0 risk score
  accountReputation String? // "TRUSTED", "NEUTRAL", "SUSPICIOUS"
  numChargebacks    Int       @default(0)
  numRefunds        Int       @default(0)
  numDisputes       Int       @default(0)
  
  // Help preferences for marketing and tailored guidance
  helpPreferences   String[]  @default([]) // Array of help category IDs the user selected

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Test environment access
  canAccessTestEnvironment Boolean @default(false) // Can see and interact with test products
  testEnvironmentAccessGrantedAt DateTime? // When test access was granted
  testEnvironmentAccessGrantedBy String? // Who granted test access (admin ID)
  
  // QA Mode - Full behavioral telemetry for controlled group
  isQaUser Boolean @default(false) // Enable comprehensive event logging for this user
  
  DeviceFingerprint DeviceFingerprint[]
  UserActivityLog   UserActivityLog[]
  temporaryUploads  TemporaryUpload[]
  qaEvents          QaEvent[]
}

model RolePermission {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  role       String // Changed from UserRole to String
  permission String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([role, permission])
  @@index([role])
  @@index([permission])
}

model Member {
  id                 String @id @default(auto()) @map("_id") @db.ObjectId
  userId             String @unique
  user               User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Address {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  encryptedStreet   String // Encrypted street address
  streetIV          String // IV for street address
  streetSalt        String // Salt for street address
  encryptedStreet2  String? // Encrypted street address 2 (optional)
  street2IV         String? // IV for street address 2
  street2Salt       String? // Salt for street address 2
  encryptedCity     String // Encrypted city
  cityIV            String // IV for city
  citySalt          String // Salt for city
  encryptedState    String? // Encrypted state/province
  stateIV           String? // IV for state/province
  stateSalt         String? // Salt for state/province
  encryptedPostal   String // Encrypted postal code
  postalIV          String // IV for postal code
  postalSalt        String // Salt for postal code
  encryptedCountry  String // Encrypted country
  countryIV         String // IV for country
  countrySalt       String // Salt for country
  isDefault         Boolean @default(true)
  isBusinessAddress Boolean @default(false) // Flag to identify business addresses
  sellerId          String
  seller            Seller  @relation(fields: [sellerId], references: [userId])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sellerId])
}

model Seller {
  id                     String            @id @default(auto()) @map("_id") @db.ObjectId
  userId                 String            @unique
  shopName               String            @unique
  shopNameSlug           String            @unique // URL-friendly shop name
  shopTagLine            String?
  shopDescription        String?
  shopAnnouncement       String? // Shop announcement/status message
  behindTheHands         String? // Personal story about the seller and how they got started
  sellerImage            String? // URL to seller profile image
  shopBannerImage        String? // URL to shop banner image
  shopLogoImage          String? // URL to shop logo image
  preferredCurrency      String            @default("USD") // Store seller's preferred currency
  preferredWeightUnit    String            @default("lbs") // Store seller's preferred weight unit (kg/lbs)
  preferredDimensionUnit String            @default("in") // Store seller's preferred dimension unit (cm/inches)
  preferredDistanceUnit  String            @default("miles") // Store seller's preferred distance unit (km/miles)
  applicationAccepted    Boolean           @default(false)
  isFullyActivated       Boolean           @default(false) // Track if seller is fully activated and ready to sell (calculated field)
  stripeConnected        Boolean           @default(false)
  connectedAccountId     String?           @unique // Optional, but required for selling
  totalSales             Int               @default(0)
  totalProducts          Int               @default(0)
  acceptsCustom          Boolean           @default(false)
  shopValues             String[]          @default([]) // Array of shop value IDs from shop-values.ts
  valuesPreferNotToSay   Boolean           @default(false)
  // Social media links
  facebookUrl            String?
  instagramUrl           String?
  pinterestUrl           String?
  tiktokUrl              String?
  products               Product[]
  order                  Order[]
  addresses              Address[]
  shippingOptions        ShippingOption[]
  reviews                Review[]
  customOrderForms       CustomOrderForm[]
  discountCodes          DiscountCode[]
  responsiblePerson      ResponsiblePerson?
  user                   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  onboardingSteps        OnboardingStep[] // New relation to onboarding steps

  // Founding Seller Program
  isFoundingSeller       Boolean @default(false) // Whether this seller qualifies for founding seller benefits
  foundingSellerType     String? // "LEGACY" (existing sellers) or "NEW" (first 50)
  foundingSellerNumber   Int? // Position in the founding seller program (1-50 for new, null for legacy)
  firstProductCreatedAt  DateTime? // When they created their first product (used to determine founding seller status)
  foundingSellerBenefits Json? // Store specific benefits granted to this seller

  // Commission Discount System
  hasCommissionDiscount Boolean @default(false) // Whether seller currently has an active commission discount
  commissionDiscountExpiresAt DateTime? // When the commission discount expires
  commissionDiscountMonths Int @default(0) // Total months of discount earned (for tracking)

  // Location fields
  shopCountry                          String
  shopState                            String?
  shopCity                             String?
  // Encrypted location fields
  encryptedShopState                   String?
  shopStateIV                          String?
  shopStateSalt                        String?
  encryptedShopCity                    String?
  shopCityIV                           String?
  shopCitySalt                         String?

  // Shop Policies
  processingTime     String? // e.g., "1-3 business days", "3-5 business days"
  returnsPolicy      String? // Return policy description
  exchangesPolicy    String? // Exchange policy description
  damagesPolicy      String? // Policy for damaged items
  nonReturnableItems String? // Items that cannot be returned
  refundPolicy       String? // Refund policy description
  careInstructions   String? // Care and maintenance instructions for products

  // Shipping Restrictions
  excludedCountries String[] @default([]) // Array of country codes that seller doesn't ship to

  // SEO fields
  metaTitle       String? // Custom SEO title for shop page
  metaDescription String? // Custom meta description for shop page
  keywords        String[] @default([]) // SEO keywords for shop
  tags            String[] @default([]) // Shop tags for categorization
  ogTitle         String? // Open Graph title for social sharing
  ogDescription   String? // Open Graph description for social sharing
  ogImage         String? // Open Graph image for social sharing

  // Follow System
  followerCount   Int      @default(0) // Denormalized follower count for performance
  followers       Follow[] @relation("SellerFollowers") // Users following this seller

  // Website Builder
  website         Website?
  subscription    SellerSubscription?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// New OnboardingStep model for flexible onboarding tracking
model OnboardingStep {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  sellerId    String
  stepKey     String   // e.g., "application_submitted", "shop_name", "stripe_connected", "first_product", "shipping_profile"
  completed   Boolean  @default(false)
  skipped     Boolean  @default(false)
  completedAt DateTime?
  seller      Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([sellerId, stepKey]) // Ensure one record per step per seller
  @@index([sellerId])
  @@index([stepKey])
  @@index([completed])
}

model ResponsiblePerson {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  sellerId          String  @unique
  
  // Encrypted personal information fields with individual IVs and salts
  encryptedName         String
  nameIV               String
  nameSalt             String
  encryptedEmail        String
  emailIV              String
  emailSalt            String
  encryptedPhone        String
  phoneIV              String
  phoneSalt            String
  encryptedCompanyName  String
  companyNameIV        String
  companyNameSalt      String
  encryptedVatNumber    String?
  vatNumberIV          String?
  vatNumberSalt        String?
  
  // Encrypted address fields with individual IVs and salts
  encryptedStreet       String
  streetIV             String
  streetSalt           String
  encryptedStreet2      String?
  street2IV            String?
  street2Salt          String?
  encryptedCity         String
  cityIV               String
  citySalt             String
  encryptedState        String?
  stateIV              String?
  stateSalt            String?
  encryptedPostalCode   String
  postalCodeIV         String
  postalCodeSalt       String
  encryptedCountry      String
  countryIV            String
  countrySalt          String
  
  seller            Seller  @relation(fields: [sellerId], references: [userId], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SellerApplication {
  id                  String  @id @default(auto()) @map("_id") @db.ObjectId
  userId              String  @unique
  craftingProcess     String
  productTypes        String
  interestInJoining   String
  // Optional fields
  onlinePresence      String?
  yearsOfExperience   String?
  referralCode        String? // Referral code used during application
  // Required legal fields (encrypted)
  encryptedBirthdate  String
  birthdateIV         String
  birthdateSalt       String
  agreeToHandmadePolicy Boolean
  certifyOver18       Boolean
  agreeToTerms        Boolean
  applicationApproved Boolean @default(false)
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model OnboardingSurvey {
  id                    String  @id @default(auto()) @map("_id") @db.ObjectId
  userId                String  @unique
  overallExperience     String // "excellent", "good", "fair", "poor"
  clarityOfInstructions String // "very_clear", "clear", "somewhat_unclear", "very_unclear"
  difficultyLevel       String // "very_easy", "easy", "moderate", "difficult", "very_difficult"
  timeToComplete        String // "less_than_15_min", "15_30_min", "30_60_min", "1_2_hours", "more_than_2_hours"
  mostChallengingStep   String // "application", "profile_setup", "stripe_connection", "shipping_setup", "none"
  suggestions           String? // Optional text feedback
  wouldRecommend        String // "definitely", "probably", "maybe", "probably_not", "definitely_not"
  user                  User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Product {
  id                    String           @id @default(auto()) @map("_id") @db.ObjectId
  userId                String
  name                  String
  sku                   String?          // Stock Keeping Unit - optional, auto-generated if not provided
  shortDescription      String          // Short description with bullet points for product overview
  shortDescriptionBullets String[]      @default([]) // Array of bullet points for short description (max 5)
  description           Json
  price                 Int
  currency              String           @default("USD") // Store the currency code (e.g., USD, EUR, GBP)
  status                String           @default("HIDDEN")
  shippingCost          Int? // Only required if product is physical
  handlingFee           Int?
  itemWeight            Float?
  itemWeightUnit        String           @default("lbs") // Store the weight unit (kg/lbs)
  itemLength            Float?
  itemWidth             Float?
  itemHeight            Float?
  itemDimensionUnit     String           @default("in") // Store the dimension unit (cm/inches)
  shippingNotes         String?
  freeShipping          Boolean          @default(false)
  isDigital             Boolean
  stock                 Int              @default(1)
  images                String[] // Array of image URLs
  productFile           String? // Only required if product is digital
  numberSold            Int              @default(0)
  onSale                Boolean          @default(false)
  discount              Int? // Only if the product is on sale
  primaryCategory       String
  secondaryCategory     String
  tertiaryCategory      String? // Optional tertiary category
  tags                  String[]
  materialTags          String[]
  options               Json? // Array of option groups with values containing price and stock
  inStockProcessingTime Int?
  outStockLeadTime      Int?
  howItsMade            String?
  productDrop           Boolean          @default(false)
  NSFW                  Boolean          @default(false)
  order                 Order[]
  dropDate              DateTime?
  dropTime              String? // Time component for product drop
  
  // Enhanced sale scheduling
  saleStartDate         DateTime? // When the sale starts
  saleEndDate           DateTime? // When the sale ends
  saleStartTime         String? // Time component for sale start
  saleEndTime           String? // Time component for sale end
  originalPrice         Int? // Store original price before sale for easy restoration
  
  reviews               Review[]
  productInteractions   ProductInteraction[]
  wishlistItems         WishlistItem[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  seller                Seller?          @relation(fields: [userId], references: [userId])
  shippingOptionId      String?
  shippingOption        ShippingOption? @relation(fields: [shippingOptionId], references: [id])

  // Tax fields
  taxCategory String  @default("PHYSICAL_GOODS")
  taxCode     String?
  taxExempt   Boolean @default(false)

  // Test environment
  isTestProduct Boolean @default(false) // Whether this is a test product (only visible to test users)

  // SEO fields
  metaTitle       String? // Custom SEO title for product page
  metaDescription String? // Custom meta description for product page
  keywords        String[] @default([]) // SEO keywords for product
  ogTitle         String? // Open Graph title for social sharing
  ogDescription   String? // Open Graph description for social sharing
  ogImage         String? // Open Graph image for social sharing

  // GPSR (General Product Safety Regulation) compliance fields
  safetyWarnings    String? // Product safety warnings and precautions
  materialsComposition String? // Materials and composition details
  safeUseInstructions String? // Instructions for safe use
  ageRestriction    String? // Age restrictions if applicable
  chokingHazard     Boolean @default(false) // Whether product poses choking hazard
  smallPartsWarning Boolean @default(false) // Whether product contains small parts
  chemicalWarnings  String? // Chemical-related warnings
  careInstructions  String? // Care and maintenance instructions
  
  // Batch tracking for compliance and traceability
  batchNumber       String? // Format: [ProductID]-[YYYYMMDD]-B[Increment]

  // Admin-created product tracking
  createdBy         String? // User ID of admin who created this product on behalf of seller
  createdVia        String? // 'ADMIN' | 'SELLER' - tracks how product was created

  @@unique([userId, sku], name: "unique_sku_per_seller")
}

model Suggestion {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String
  title       String
  description String
  type        String // e.g., "Feature", "Change", "Addition"
  role        String // "Seller" or "Member"
  upvoteCount Int      @default(0)
  upvotes     Upvote[]

  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Upvote {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  userId       String
  suggestionId String
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id])
  suggestion   Suggestion @relation(fields: [suggestionId], references: [id])

  @@unique([userId, suggestionId])
}

model ContactUs {
  id              String @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  email           String
  reason          String
  helpDescription String

  createdAt DateTime @default(now())
}

model DMCAComplaint {
  id                    String @id @default(auto()) @map("_id") @db.ObjectId
  
  // Basic Information
  name                  String
  email                 String
  phoneNumber           String?
  
  // Product Information
  productLink           String
  infringingStatement   String
  
  // Legal Agreement
  legalAgreement        Boolean
  
  // File Upload
  copyrightDocumentUrl  String?
  
  // Status tracking
  status               String @default("PENDING") // PENDING, REVIEWING, RESOLVED, REJECTED
  adminNotes           String?
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Order {
  id                       String        @id @default(auto()) @map("_id") @db.ObjectId
  userId                   String? // Optional to support guest checkouts
  encryptedBuyerEmail      String
  buyerEmailIV             String
  buyerEmailSalt           String
  encryptedBuyerName       String
  buyerNameIV              String
  buyerNameSalt            String
  sellerId                 String
  shopName                 String
  productId                String
  productName              String
  quantity                 Int
  totalAmount              Float
  currency                 String        @default("USD") // Store the currency code used for the order
  productPrice             Float
  shippingCost             Float
  stripeFee                Float         @default(0)
  platformFee              Float         @default(0) // Platform/marketplace fee collected
  taxAmount                Float         @default(0) // Total tax amount collected
  taxJurisdiction          String? // Country/State where tax was collected
  taxRate                  Float? // Tax rate applied (e.g., 0.08 for 8%)
  taxType                  String? // Type of tax (e.g., "VAT", "GST", "Sales Tax")
  taxBreakdown             Json? // Detailed breakdown of taxes by type and jurisdiction
  taxExempt                Boolean       @default(false) // Whether the order was tax exempt
  taxCategory              String? // Product tax category
  taxCode                  String? // Stripe tax code used
  isDigital                Boolean       @default(false)
  status                   OrderStatus
  paymentStatus            PaymentStatus
  stripeSessionId          String
  stripeTransferId         String?
  encryptedShippingAddress String
  shippingAddressIV        String
  shippingAddressSalt      String
  encryptedBillingAddress  String?
  billingAddressIV         String?
  billingAddressSalt       String?
  discount                 Json?
  
  // Discount code fields
  discountCodeId           String? // Applied discount code
  discountCodeAmount       Float @default(0) // Amount saved from discount code
  discountCodeUsed         String? // The actual code that was used
  
  // Exchange rate fields
  exchangeRate             Float? // The exchange rate used for this order (e.g., 1.2 for USD to EUR)
  baseCurrency             String        @default("USD") // The original currency (usually USD)
  exchangeRateTimestamp    DateTime? // When the exchange rate was fetched
  reviews                  Review[]
  completedAt              DateTime?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  user                     User?         @relation(fields: [userId], references: [id]) // Optional relation for guest checkouts
  seller                   Seller        @relation(fields: [sellerId], references: [userId])
  product                  Product       @relation(fields: [productId], references: [id])
  discountCodeUsage        DiscountCodeUsage?

  //Tracability and fraud detection
  buyerIp                  String?
  buyerLocation            Json?
  buyerDeviceId            String?
  
  // Digital download tracking
  digitalDownloadAttempted Boolean @default(false)
  digitalDownloadedAt      DateTime?
  
  // Product traceability
  batchNumber              String? // Product batch number for traceability
}

model HandmadeGuidelines {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PrivacyPolicy {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TermsOfService {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BuyerAndReturnsPolicy {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProhibitedItemsPolicy {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CopyrightInfringement {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TemporaryUpload {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  fileKey   String   @unique
  fileUrl   String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  productId String? // Optional, will be set when the file is associated with a product

  @@index([createdAt]) // Add index for better query performance
  @@index([userId]) // Add index for user queries
}

model Review {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId    String
  sellerId   String // Direct reference to the seller
  reviewerId String
  reviewedId String
  productId  String?
  rating     Int // 1-5 stars
  comment    String?
  type       String // "PRODUCT", "SELLER", "BUYER"
  status     String   @default("PENDING") // "PENDING", "PUBLISHED", "EXPIRED"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  expiresAt  DateTime // 2 weeks from order completion
  order      Order    @relation(fields: [orderId], references: [id])
  seller     Seller   @relation(fields: [sellerId], references: [id])
  reviewer   User     @relation("Reviewer", fields: [reviewerId], references: [id])
  reviewed   User     @relation("Reviewed", fields: [reviewedId], references: [id])
  product    Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([sellerId])
  @@index([reviewerId])
  @@index([reviewedId])
  @@index([productId])
}

model Message {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  content        String
  senderId       String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String             @id @default(auto()) @map("_id") @db.ObjectId
  users     UserConversation[]
  messages  Message[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model UserConversation {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, conversationId])
}

model CustomerFeedback {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  heardFrom         String
  overallExperience Int // 1-5 rating
  placedOrder       String // "YES", "PLANNING", "NO"
  orderNumber       String?
  experience        String
  improvements      String?
  returnLikelihood  Int // 1-5 rating
  email             String?
  website           String? // Honeypot field
  recaptchaToken    String?

  createdAt DateTime @default(now())
}

// New model for storing exchange rates
model ExchangeRate {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  baseCurrency   String // Base currency (e.g., USD)
  targetCurrency String // Target currency (e.g., EUR)
  rate           Float // Exchange rate value
  lastUpdated    DateTime @default(now())
  isActive       Boolean  @default(true)

  @@unique([baseCurrency, targetCurrency])
  @@index([baseCurrency])
  @@index([targetCurrency])
}

model BlogPost {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  publishedAt DateTime? // When the post was published
  slug        String        @unique
  title       String
  description String
  content     Json // Rich text content
  contentBlocks Json? // Structured content blocks (cards, steps, alerts, tables, etc.)
  excerpt     String? // Short summary for previews
  img         String? // Featured image
  views       Int           @default(0)
  readTime    Int? // Estimated reading time in minutes
  status      String        @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  catSlug     String
  cat         BlogCategory  @relation(fields: [catSlug], references: [slug])
  userEmail   String
  user        User          @relation(fields: [userEmail], references: [email])
  comments    BlogComment[] @relation("BlogCommentToBlogPost")

  // SEO fields
  metaTitle       String? // Custom SEO title
  metaDescription String? // Custom meta description
  keywords        String[] // SEO keywords
  canonicalUrl    String? // Canonical URL for duplicate content
  ogImage         String? // Open Graph image for social sharing
  ogTitle         String? // Open Graph title
  ogDescription   String? // Open Graph description

  // Schema.org structured data
  authorUrl    String? // Author's profile URL
  dateModified DateTime? // Last modification date for structured data

  // Additional metadata
  tags          String[] // Blog post tags
  featured      Boolean  @default(false)
  allowComments Boolean  @default(true)
  isPrivate     Boolean  @default(false)

  @@index([status])
  @@index([publishedAt])
  @@index([tags])
  @@index([catSlug])
}

model BlogComment {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  desc      String
  userEmail String
  user      User          @relation(fields: [userEmail], references: [email])
  postSlug  String
  post      BlogPost      @relation("BlogCommentToBlogPost", fields: [postSlug], references: [slug], onDelete: Cascade)
  parentId  String? // For nested comments
  parent    BlogComment?  @relation("CommentToComment", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies   BlogComment[] @relation("CommentToComment")
  isEdited  Boolean       @default(false)
  isHidden  Boolean       @default(false)
  likes     Int           @default(0)

  @@index([postSlug])
  @@index([userEmail])
  @@index([parentId])
}

model BlogCategory {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  slug        String         @unique
  title       String
  description String? // Category description for SEO
  img         String?
  posts       BlogPost[]
  parentSlug  String? // For nested categories
  parent      BlogCategory?  @relation("CategoryToCategory", fields: [parentSlug], references: [slug], onDelete: NoAction, onUpdate: NoAction)
  children    BlogCategory[] @relation("CategoryToCategory")
  order       Int            @default(0) // For custom ordering
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([parentSlug])
  @@index([order])
}

model HelpArticle {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  publishedAt DateTime? // When the article was published
  slug        String        @unique
  title       String
  description String
  contentBlocks Json? // Structured content blocks (cards, steps, alerts, tables, etc.)
  excerpt     String? // Short summary for previews
  views       Int           @default(0)
  readTime    Int? // Estimated reading time in minutes
  status      String        @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  catSlug     String
  cat         HelpCategory  @relation(fields: [catSlug], references: [slug])
  userEmail   String
  user        User          @relation(fields: [userEmail], references: [email])

  // SEO fields
  metaTitle       String? // Custom SEO title
  metaDescription String? // Custom meta description
  keywords        String[] // SEO keywords
  canonicalUrl    String? // Canonical URL for duplicate content
  ogImage         String? // Open Graph image for social sharing
  ogTitle         String? // Open Graph title
  ogDescription   String? // Open Graph description

  // Schema.org structured data
  authorUrl    String? // Author's profile URL
  dateModified DateTime? // Last modification date for structured data

  // Additional metadata
  tags          String[] // Help article tags
  featured      Boolean  @default(false)
  isPrivate     Boolean  @default(false)
  order         Int      @default(0) // For custom ordering within category
  targetAudience String  @default("BOTH") // BUYERS, SELLERS, BOTH

  @@index([status])
  @@index([publishedAt])
  @@index([tags])
  @@index([catSlug])
  @@index([order])
}

model HelpCategory {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  slug        String         @unique
  title       String
  description String? // Category description for SEO
  articles    HelpArticle[]
  parentSlug  String? // For nested categories
  parent      HelpCategory?  @relation("HelpCategoryToHelpCategory", fields: [parentSlug], references: [slug], onDelete: NoAction, onUpdate: NoAction)
  children    HelpCategory[] @relation("HelpCategoryToHelpCategory")
  order       Int            @default(0) // For custom ordering
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([parentSlug])
  @@index([order])
}

model ShippingOption {
  id                   String         @id @default(auto()) @map("_id") @db.ObjectId
  name                 String
  isDefault            Boolean        @default(false)
  countryOfOrigin      String // Country where the products are shipped from
  defaultShipping      Int? // Default worldwide shipping cost in cents
  defaultShippingCurrency String @default("USD") // Currency for default shipping
  sellerId             String
  seller               Seller         @relation(fields: [sellerId], references: [userId])
  rates                ShippingRate[]
  products             Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sellerId])
}

model ShippingRate {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  profileId       String
  type            String // "zone" or "country"
  zone            String? // e.g., "NORTH_AMERICA", "EUROPE", etc. (required for zone type, determined from countryCode for country type)
  countryCode     String? // Country code (required for country type, null for zone type)
  price           Int // In cents
  additionalItem  Int? // Optional: charge extra per item
  isFreeShipping  Boolean @default(false)

  shippingOption ShippingOption @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model Admin {
  id                      String   @id @default(cuid()) @map("_id")
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role                    String // Maps to ADMIN_ROLES from data/roles-and-permissions.ts
  isActive                Boolean  @default(true)
  assignedRegions         String[] // Array of region codes or names
  notificationPreferences Json? // Array of notification preferences
  tasks                   Json? // Array of task objects
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("Admin")
}

model DeviceFingerprint {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id])
  deviceId  String // SHA256 hash of entropy data
  ip        String
  location  Json?
  isProxy   Boolean?
  userAgent String?
  browser   String?
  os        String?
  screenRes String?
  timezone  String?
  language  String?
  firstSeen DateTime @default(now())
  lastSeen  DateTime @updatedAt

  @@unique([deviceId, userId])
  @@index([deviceId])
  @@index([userId])
}

model UserActivityLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  action    String // "LOGIN", "SIGNUP", "CHECKOUT", "FAILED_LOGIN", "PASSWORD_RESET", "PROFILE_UPDATE", "SETTINGS_CHANGE"
  ip        String
  location  Json?
  userAgent String?
  deviceId  String?
  success   Boolean?
  details   Json? // Optional: { orderId, productId, errorCode, ... }
  
  // Enhanced tracking
  sessionId String?  // Session identifier
  pageUrl   String?  // Page where action occurred
  referrer  String?  // Previous page
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([deviceId])
  @@index([sessionId])
}

// Abandoned Cart Analytics Model
model AbandonedCart {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionId         String   @unique // Unique session identifier
  userId            String?  // Optional - can be guest checkout
  user              User?    @relation(fields: [userId], references: [id])
  
  // Product information
  productId         String
  productName       String
  price             Int // In cents
  quantity          Int
  total             Int // In cents
  isDigital         Boolean
  sellerId          String?
  
  // Checkout progress
  stepsCompleted    String[] // Array of completed steps
  lastStep          String?  // Last step before abandonment
  timeSpent         Int      // Time spent in seconds
  abandonmentReason String?  // Why they abandoned
  
  // User behavior
  fieldInteractions String[] // Which form fields they interacted with
  pageViews         Int      @default(1)
  scrollDepth       Float?   // Percentage of page scrolled
  
  // Technical details
  userAgent         String?
  ipAddress         String?
  location          Json?    // Geographic location data
  deviceType        String?  // mobile, desktop, tablet
  
  // Recovery attempts
  recoveryEmailsSent Int     @default(0)
  lastRecoveryEmail  DateTime?
  recovered          Boolean @default(false)
  recoveredAt        DateTime?
  
  // Metadata
  metadata          Json?    // Additional tracking data
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([productId])
  @@index([sellerId])
  @@index([abandonmentReason])
  @@index([createdAt])
  @@index([recovered])
}

// Custom Order Form Models
model CustomOrderForm {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  sellerId    String
  seller      Seller   @relation(fields: [sellerId], references: [userId])
  title       String
  description String?
  isActive    Boolean  @default(true)
  fields      CustomOrderFormField[]
  submissions CustomOrderSubmission[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sellerId])
  @@index([isActive])
}

model CustomOrderFormField {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  formId            String
  form              CustomOrderForm  @relation(fields: [formId], references: [id], onDelete: Cascade)
  label             String
  type              String // "text", "textarea", "number", "email", "phone", "select", "multiselect", "file", "date", "boolean"
  required          Boolean          @default(false)
  placeholder       String?
  helpText          String?
  options           String[]         @default([]) // For select/multiselect fields
  validation        Json? // Custom validation rules
  order             Int // Field order in the form
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  responses         CustomOrderSubmissionResponse[]

  @@index([formId])
  @@index([order])
}

model CustomOrderSubmission {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  formId    String
  form      CustomOrderForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  userId    String // Required - customer must be logged in
  user      User   @relation(fields: [userId], references: [id])
  customerEmail String
  customerName  String?
  status    String  @default("PENDING") // "PENDING", "REVIEWED", "APPROVED", "REJECTED", "COMPLETED", "READY_FOR_FINAL_PAYMENT"
  responses CustomOrderSubmissionResponse[]
  notes     String? // Seller's notes on the submission
  
  // Payment fields
  materialsDepositAmount Int? // Amount in cents for materials deposit
  finalPaymentAmount     Int? // Amount in cents for final payment (excluding materials)
  totalAmount            Int? // Total amount in cents (materials + final)
  currency               String @default("USD")
  
  // Payment status
  materialsDepositPaid   Boolean @default(false)
  finalPaymentPaid       Boolean @default(false)
  materialsDepositSessionId String? // Stripe session ID for materials payment
  finalPaymentSessionId     String? // Stripe session ID for final payment
  
  // Shipping information (filled when ready for final payment)
  shippingAddress        Json? // Encrypted shipping address
  shippingAddressIV      String?
  shippingAddressSalt    String?
  shippingCost           Int? // Shipping cost in cents
  
  // Payment records
  payments               CustomOrderPayment[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([formId])
  @@index([userId])
  @@index([status])
  @@index([customerEmail])
}

model CustomOrderSubmissionResponse {
  id         String                @id @default(auto()) @map("_id") @db.ObjectId
  submissionId String
  submission CustomOrderSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  fieldId    String
  field      CustomOrderFormField  @relation(fields: [fieldId], references: [id])
  value      String // Store response as string, parse based on field type
  createdAt  DateTime              @default(now())

  @@unique([submissionId, fieldId])
  @@index([submissionId])
  @@index([fieldId])
}

// Custom Order Payment Records (for tracking payments)
model CustomOrderPayment {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  submissionId      String
  submission        CustomOrderSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  paymentType       String // "MATERIALS_DEPOSIT" or "FINAL_PAYMENT"
  amount            Int // Amount in cents
  currency          String @default("USD")
  stripeSessionId   String
  stripePaymentIntentId String?
  status            String @default("PENDING") // "PENDING", "COMPLETED", "FAILED", "REFUNDED"
  platformFee       Int @default(0) // Platform fee in cents
  sellerAmount      Int // Amount that goes to seller in cents
  
  // Tax information
  taxAmount         Int @default(0)
  taxJurisdiction   String?
  taxRate           Float?
  taxType           String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([submissionId])
  @@index([stripeSessionId])
  @@index([status])
}

// Newsletter Subscription Model
model NewsletterSubscription {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique // Email address for subscription
  firstName String?  // Optional first name
  lastName  String?  // Optional last name
  isActive  Boolean  @default(true) // Whether subscription is active
  source    String?  // Where they subscribed from (e.g., "website", "checkout", "popup")
  ipAddress String?  // IP address for tracking
  userAgent String?  // User agent for tracking
  location  Json?    // Location data if available
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([createdAt])
}

// Discount Code Models
model DiscountCode {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  sellerId              String
  seller                Seller   @relation(fields: [sellerId], references: [userId])
  code                  String   @unique // The actual discount code (e.g., "SUMMER20")
  name                  String // Display name for the discount
  description           String? // Optional description
  discountType          String // "PERCENTAGE" or "FIXED_AMOUNT"
  discountValue         Int // Percentage (1-100) or amount in cents
  minimumOrderAmount    Int? // Minimum order amount in cents to apply discount
  maximumDiscountAmount Int? // Maximum discount amount in cents (for percentage discounts)
  
  // Usage limits
  maxUses               Int? // Maximum times this code can be used
  maxUsesPerCustomer    Int? // Maximum times per customer
  currentUses           Int   @default(0) // Current usage count
  
  // Expiration
  expiresAt             DateTime?
  isActive              Boolean @default(true)
  
  // Applicability
  appliesToAllProducts  Boolean @default(true) // If false, use product-specific rules
  applicableProductIds  String[] @default([]) // Specific product IDs
  applicableCategories  String[] @default([]) // Category names to apply to
  
  // Stacking rules
  stackableWithProductSales Boolean @default(true) // Can be used with product-level sales
  
  // Tracking
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  usages                DiscountCodeUsage[]

  @@index([sellerId])
  @@index([isActive])
  @@index([expiresAt])
}

model DiscountCodeUsage {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  discountCodeId String
  discountCode   DiscountCode  @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)
  orderId        String @unique
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId         String? // Customer who used the code (optional for guest checkouts)
  discountAmount Int // Amount of discount applied in cents
  usedAt         DateTime @default(now())

  @@index([discountCodeId])
  @@index([userId])
}

// Unified Analytics System
model PlatformAnalytics {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  date              DateTime @default(now())
  type              String // "DAILY", "WEEKLY", "MONTHLY"
  
  // Context fields (null for platform-wide, populated for specific contexts)
  sellerId          String? // null = platform-wide, populated = seller-specific
  productId         String? // null = platform/seller-wide, populated = product-specific
  category          String? // Category-specific analytics
  country           String? // Country-specific analytics
  
  // Core metrics (always populated)
  totalOrders       Int      @default(0)
  totalRevenue      Int      @default(0) // In cents
  totalViews        Int      @default(0)
  uniqueVisitors    Int      @default(0)
  conversionRate    Float    @default(0) // Orders / Views
  averageOrderValue Int      @default(0) // In cents
  
  // Context-specific metrics (stored as JSON for flexibility)
  metrics           Json? // Flexible structure for different contexts
  
  // Examples of metrics structure:
  // Platform-wide: { totalSellers, totalBuyers, cartAbandonmentRate, fraudAttempts }
  // Seller-specific: { uniqueCustomers, repeatCustomers, averageRating, chargebacks }
  // Product-specific: { addToCart, timeOnPage, searchRanking, shares }
  // Category-specific: { categoryPerformance, topProducts, marketShare }
  // Geographic: { localConversionRate, shippingDestinations, regionalTrends }
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([type])
  @@index([sellerId])
  @@index([productId])
  @@index([category])
  @@index([country])
  @@index([sellerId, date])
  @@index([productId, date])
}

model FraudDetectionEvent {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String?
  user              User?    @relation(fields: [userId], references: [id])
  eventType         String // "SUSPICIOUS_LOGIN", "UNUSUAL_ORDER", "CHARGEBACK", "DISPUTE", "VPN_DETECTED", "MULTIPLE_ACCOUNTS"
  severity          String // "LOW", "MEDIUM", "HIGH", "CRITICAL"
  riskScore         Float    @default(0) // 0.0-1.0
  
  // Event details
  description       String
  evidence          Json? // Detailed evidence and data
  ipAddress         String?
  userAgent         String?
  location          Json?
  
  // Order context (if applicable)
  orderId           String?
  productId         String?
  sellerId          String?
  
  // Resolution
  status            String   @default("OPEN") // "OPEN", "INVESTIGATING", "RESOLVED", "FALSE_POSITIVE"
  resolvedBy        String? // Admin ID who resolved it
  resolutionNotes   String?
  resolvedAt        DateTime?
  
  // Automated actions
  actionsTaken      String[] @default([]) // Array of actions like ["FLAG_ACCOUNT", "HOLD_ORDER", "REQUIRE_VERIFICATION"]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([eventType])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

// User Behavior Tracking Models
model UserBehaviorEvent {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String?  // Optional for guest users
  user              User?    @relation(fields: [userId], references: [id])
  sessionId         String   // Unique session identifier
  eventType         String   // "PAGE_VIEW", "CLICK", "SCROLL", "HOVER", "FORM_INTERACTION", "NAVIGATION", "MOUSE_MOVEMENT"
  pageUrl           String   // Current page URL
  referrerUrl       String?  // Previous page URL
  elementId         String?  // DOM element ID if applicable
  elementType       String?  // "button", "link", "form", "image", etc.
  elementText       String?  // Text content of the element
  interactionData   Json?    // Additional interaction details
  
  // Timing and performance
  timestamp         DateTime @default(now())
  timeOnPage        Int?     // Time spent on page in seconds
  scrollDepth       Float?   // Percentage of page scrolled (0-100)
  mouseMovements    Int?     // Number of mouse movements
  clicks            Int?     // Number of clicks on page
  
  // Enhanced mouse movement tracking for fraud detection
  mouseX            Int?     // X coordinate of mouse
  mouseY            Int?     // Y coordinate of mouse
  mouseVelocity     Float?   // Speed of mouse movement (pixels/ms)
  mouseAcceleration Float?   // Change in velocity
  mouseDirection    String?  // Direction of movement (N, S, E, W, NE, NW, SE, SW)
  mouseDistance     Float?   // Distance from previous position
  mousePauseTime    Int?     // Time paused at position (ms)
  
  // Human behavior patterns
  movementPattern   String?  // "NATURAL", "LINEAR", "GRID", "RANDOM", "BOT_LIKE"
  clickPattern      String?  // "NATURAL", "PRECISE", "RAPID", "UNIFORM"
  scrollPattern     String?  // "NATURAL", "SMOOTH", "JERKY", "LINEAR"
  
  // Device and location
  deviceId          String?  // Device fingerprint ID
  ipAddress         String?
  userAgent         String?
  location          Json?    // Geographic location data
  
  // Session context
  isFirstVisit      Boolean  @default(false)
  visitNumber       Int?     // Which visit this is for the user
  sessionDuration   Int?     // Total session duration in seconds
  
  // Fraud detection flags
  suspiciousBehavior Boolean @default(false)
  botProbability    Float?   // 0-1 score indicating likelihood of bot
  riskScore         Float?   // Overall risk score for this event
  
  createdAt         DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([eventType])
  @@index([timestamp])
  @@index([deviceId])
  @@index([suspiciousBehavior])
  @@index([botProbability])
}

model SearchAnalytics {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String?  // Optional for guest users (only when logged in)
  user              User?    @relation(fields: [userId], references: [id])
  sessionId         String?  // Session identifier (optional for advanced analytics)
  
  // Core search fields (minimum tracking)
  searchQuery       String   // The raw string the user typed
  normalizedQuery   String   // Cleaned-up version: lowercase, trimmed, punctuation removed
  resultCount       Int      // Total results your search engine returned
  clickProductId    String?  // If they clicked something immediately after the search (product ID only)
  
  // Device and location (minimum tracking)
  deviceId          String   // UUID cookie + fallback to localStorage (must have)
  deviceType        String?  // "desktop", "mobile", "tablet"
  ipAddress         String?  // IP address (truncate to /24 if privacy-respectful)
  location          Json?    // { country, region/state } - NOTHING more detailed
  
  // Context and metadata (minimum tracking)
  timestamp         DateTime @default(now())
  searchContext     String?  // What page they searched from: "homepage", "category-page", "seller-shop", "global search bar"
  
  // Advanced fields (for future use - keep in model but optional)
  queryLength       Int?     // Length of search query
  searchType        String?  // "PRODUCT", "CATEGORY", "SELLER", "GENERAL"
  filters           Json?    // Applied filters (category, price, location, etc.) - searchFilters
  sortBy            String?  // Sort method used
  resultsShown      Int?     // Number of results displayed
  clickedResult     Int?     // Position of clicked result (1-based)
  clickedSellerId   String?  // ID of clicked seller
  timeToClick       Int?     // Time from search to first click in milliseconds
  searchRefinement  Boolean  @default(false) // Whether user refined the search
  originalQuery     String?  // Original query if refined
  searchTime        Int?     // Time taken for search in milliseconds
  userAgent         String?  // User agent string

  @@index([userId])
  @@index([sessionId])
  @@index([searchQuery])
  @@index([normalizedQuery])
  @@index([searchType])
  @@index([timestamp])
  @@index([deviceId])
  @@index([searchContext])
}

model ProductInteraction {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String?  // Optional for guest users
  user              User?    @relation(fields: [userId], references: [id])
  productId         String   @db.ObjectId
  product           Product  @relation(fields: [productId], references: [id])
  sessionId         String   // Session identifier
  
  // Interaction details
  interactionType   String   // "VIEW", "CLICK", "ADD_TO_CART", "REMOVE_FROM_CART", "FAVORITE", "SHARE", "REVIEW_VIEW"
  interactionData   Json?    // Additional interaction details
  
  // View-specific data
  timeOnProduct     Int?     // Time spent viewing product in seconds
  imagesViewed      Int?     // Number of images viewed
  descriptionRead   Boolean  @default(false) // Whether description was read
  reviewsViewed     Int?     // Number of reviews viewed
  sellerInfoViewed  Boolean  @default(false) // Whether seller info was viewed
  
  // Source tracking
  sourceType        String?  // "SEARCH", "CATEGORY", "RECOMMENDATION", "DIRECT", "SOCIAL", "EMAIL"
  sourceId          String?  // ID of source (search query, category, etc.)
  referrerUrl       String?  // Previous page URL
  
  // Device and location
  deviceId          String?  // Device fingerprint ID
  ipAddress         String?
  userAgent         String?
  location          Json?    // Geographic location data
  
  timestamp         DateTime @default(now())

  @@index([userId])
  @@index([productId])
  @@index([sessionId])
  @@index([interactionType])
  @@index([timestamp])
  @@index([deviceId])
}

model UserSession {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String?  // Optional for guest users
  user              User?    @relation(fields: [userId], references: [id])
  sessionId         String   @unique // Unique session identifier
  
  // Session details
  startTime         DateTime @default(now())
  endTime           DateTime? // When session ended
  duration          Int?     // Session duration in seconds
  isActive          Boolean  @default(true)
  
  // Device and location
  deviceId          String?  // Device fingerprint ID
  ipAddress         String?
  userAgent         String?
  location          Json?    // Geographic location data
  browser           String?
  os                String?
  deviceType        String?  // "desktop", "mobile", "tablet"
  
  // Session metrics
  pageViews         Int      @default(0)
  uniquePages       Int      @default(0)
  searches          Int      @default(0)
  productViews      Int      @default(0)
  cartAdditions     Int      @default(0)
  purchases         Int      @default(0)
  
  // User context
  isFirstVisit      Boolean  @default(false)
  visitNumber       Int?     // Which visit this is for the user
  returningUser     Boolean  @default(false)
  
  // Conversion tracking
  converted         Boolean  @default(false) // Whether session led to purchase
  conversionValue   Int?     // Value of conversion in cents
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([startTime])
  @@index([deviceId])
  @@index([isActive])
}

// Report System Models
model Report {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  reporterId        String?  // Optional for anonymous reports
  reporter          User?    @relation("ReportReporter", fields: [reporterId], references: [id])
  
  // Report target
  reportType        String   // "SELLER" or "PRODUCT"
  targetId          String   // ID of the seller or product being reported
  targetName        String   // Name of the seller shop or product for easy reference
  
  // Report details
  reason            String   // Primary reason for report
  subReason         String?  // Secondary reason if applicable
  description       String   // Detailed description of the issue
  evidence          String?  // Additional evidence or context
  
  // Report categories
  category          String   // "INAPPROPRIATE_CONTENT", "COPYRIGHT_INFRINGEMENT", "MISLEADING_INFORMATION", "POOR_QUALITY", "FAKE_PRODUCTS", "HARASSMENT", "SPAM", "OTHER"
  severity          String   @default("MEDIUM") // "LOW", "MEDIUM", "HIGH", "CRITICAL"
  
  // Status tracking
  status            String   @default("PENDING") // "PENDING", "UNDER_REVIEW", "RESOLVED", "DISMISSED", "ESCALATED"
  adminNotes        String?  // Internal notes from admin review
  resolutionNotes   String?  // Notes about how the report was resolved
  resolvedBy        String?  // Admin ID who resolved the report
  resolvedAt        DateTime?
  
  // Contact information (for anonymous reports)
  reporterEmail     String?  // Email for follow-up (optional)
  reporterName      String?  // Name for follow-up (optional)
  
  // Metadata
  ipAddress         String?  // IP address of reporter
  userAgent         String?  // User agent of reporter
  location          Json?    // Geographic location data
  
  // Related reports (for tracking patterns)
  relatedReportIds  String[] @default([]) // IDs of related reports
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([reporterId])
  @@index([reportType])
  @@index([targetId])
  @@index([category])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
  @@index([reportType, targetId]) // For finding all reports for a specific seller/product
}

// Follow System Model
model Follow {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  followerId String   @db.ObjectId   // The user doing the following
  sellerId   String   @db.ObjectId   // The seller being followed
  createdAt  DateTime @default(now())

  // Relations
  follower User   @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  seller   Seller @relation("SellerFollowers", fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([followerId, sellerId]) // Prevent duplicate follows
  @@index([sellerId])              // Fast lookup for seller's followers
  @@index([followerId])            // Fast lookup for a user's following
  @@index([createdAt])             // For chronological ordering
}

model Wishlist {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  userId          String         @db.ObjectId
  name            String
  description     String?
  coverImage      String?        // Auto-generated from first item if blank
  slug            String         @unique // For clean URLs like yarnnu.com/w/xmas2025-abc123
  privacy         WishlistPrivacy @default(PRIVATE)
  allowPurchases  Boolean        @default(false) // Can others buy directly from this wishlist?
  hideOnPurchase  Boolean        @default(false) // Hide items when purchased (surprise mode)
  isDefault       Boolean        @default(false) // Is this the user's default wishlist?
  
  // Relationships
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           WishlistItem[]
  analytics       WishlistAnalytics?
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId])
  @@index([privacy])
}

model WishlistItem {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  wishlistId  String    @db.ObjectId
  productId   String    @db.ObjectId
  userId      String    @db.ObjectId // User who owns the wishlist
  purchased   Boolean   @default(false)
  purchasedBy String?   @db.ObjectId // Who purchased it (if allowPurchases = true)
  purchasedAt DateTime?
  notes       String?   // Personal notes about this item
  
  // Relationships
  wishlist    Wishlist  @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchaser   User?     @relation("WishlistPurchaser", fields: [purchasedBy], references: [id])
  user        User      @relation("UserWishlistItems", fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([wishlistId, productId]) // Prevent duplicate items in same wishlist
  @@index([wishlistId])
  @@index([productId])
  @@index([purchased])
}

model WishlistAnalytics {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  wishlistId            String   @unique @db.ObjectId
  totalViews            Int      @default(0)
  uniqueVisitors        Int      @default(0)
  sharesGenerated       Int      @default(0) // QR codes generated, links shared
  socialShares          Json     @default("{}") // Track which platforms: {facebook: 5, twitter: 3, etc}
  lastViewedAt          DateTime?
  
  // Relationships
  wishlist              Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

enum WishlistPrivacy {
  PRIVATE        // Only owner can see
  PUBLIC         // Searchable, shows in profile
  SHAREABLE      // Only accessible via link/QR
}

// Website Builder Models
model Website {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  sellerId      String       @unique
  seller        Seller       @relation(fields: [sellerId], references: [id])
  name          String
  description   String?
  published     Boolean      @default(false)
  subDomainName String?      @unique // For subdomain like seller.yarnnu.com
  customDomain  String?      @unique // Custom domain if available
  favicon       String?      // Favicon URL
  websiteSlug   String?      @unique // URL slug for the website
  theme         String?      // Selected theme/template
  settings      Json?        // Custom settings, colors, fonts, etc.
  seoTitle      String?      // SEO title
  seoDescription String?     // SEO description
  ogImage       String?      // Open Graph image
  
  pages         WebsitePage[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([published])
}

model WebsitePage {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  websiteId    String
  website      Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  name         String
  pathName     String   @default("") // URL path for the page
  content      String?  // JSON string of page content (EditorElement[])
  order        Int      @default(0) // Page order in navigation
  isHomepage   Boolean  @default(false)
  isPublished  Boolean  @default(false)
  visits       Int      @default(0) // Page visit counter
  previewImage String?  // Preview image for the page
  
  // SEO fields
  seoTitle       String?
  seoDescription String?
  ogImage        String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([websiteId, pathName])
  @@index([websiteId])
  @@index([isPublished])
  @@index([order])
}

// Subscription Plans for Yarnnu (Starter, Maker, Studio)
model SubscriptionPlan {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String   @unique // "STARTER", "MAKER", "STUDIO"
  displayName     String   // "Starter", "Maker", "Studio"
  price           Int      // Monthly price in cents
  currency        String   @default("USD")
  features        Json     // Array of features included
  customDomain    Boolean  @default(false)
  analytics       Boolean  @default(false)
  prioritySupport Boolean  @default(false)
  websiteBuilder  Boolean  @default(false) // Only Studio plan has this
  stripePriceId   String?  // Stripe price ID
  isActive        Boolean  @default(true)
  
  subscriptions   SellerSubscription[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Seller Subscriptions
model SellerSubscription {
  id                    String            @id @default(auto()) @map("_id") @db.ObjectId
  sellerId              String            @unique
  seller                Seller            @relation(fields: [sellerId], references: [id])
  planId                String
  plan                  SubscriptionPlan  @relation(fields: [planId], references: [id])
  status                String            @default("ACTIVE") // ACTIVE, CANCELLED, PAST_DUE, TRIALING
  stripeSubscriptionId  String?           @unique
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  trialEndsAt           DateTime?
  cancelAtPeriodEnd     Boolean           @default(false)
  
  // Website Builder specific (only available in Studio plan)
  customDomain          String?
  websiteSlug           String?           @unique // For subdomain like seller.yarnnu.com
  
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  
  @@index([status])
}

// Website Builder Templates
model WebsiteTemplate {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  description   String
  category      String   // "MINIMAL", "MODERN", "VINTAGE", "CREATIVE"
  previewImage  String
  content       Json     // Template structure (EditorElement[])
  isActive      Boolean  @default(true)
  isPremium     Boolean  @default(false)
  price         Int?     // Price in cents if premium
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Error Logging System
model ErrorLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  level     String   // "info" | "warn" | "error" | "fatal"
  code      String   // Error code like "PRODUCT_CREATE_FAILED"
  message   String   // Human-readable error message
  userId    String?  // Optional user ID if error is user-specific
  route     String?  // API route or page path (e.g., "/api/products")
  method    String?  // HTTP method (e.g., "POST", "GET")
  metadata  Json?    // Additional context (payload, browser, file size, etc.)
  error     Json?    // Full error object (stack trace, name, etc.)
  createdAt DateTime @default(now())

  @@index([level])
  @@index([code])
  @@index([userId])
  @@index([route])
  @@index([createdAt])
  @@index([code, createdAt])
}

// QA Event Logging System - Separate from error logs
// This tracks behavioral telemetry for QA users (success + failure events)
model QaEvent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   // Required - only QA users generate these events
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String   // Session identifier for replaying user flows
  event     String   // Event category like "PRODUCT_CREATE", "CHECKOUT", "SELLER_ONBOARDING"
  step      String?  // Specific step within the event flow (e.g., "IMAGES", "PRICING")
  status    String   // "started" | "completed" | "failed"
  route     String?  // Current route/page where event occurred
  metadata  Json?    // Additional context (form data, API payload, browser info, etc.)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([event])
  @@index([status])
  @@index([createdAt])
  @@index([userId, sessionId]) // For replaying specific user sessions
  @@index([event, status]) // For finding failure patterns
}


